# EditorConfig: https://editorconfig.org
# Ensures consistent whitespace and line endings across all editors.

root = true

[*]
charset             = utf-8
end_of_line         = lf
indent_style        = space
indent_size         = 2
insert_final_newline  = true
trim_trailing_whitespace = true

[*.md]
# Trailing spaces in Markdown can be intentional (line break)
trim_trailing_whitespace = false

[*.yml]
indent_size = 2

[*.json]
indent_size = 2

[Makefile]
indent_style = tab
